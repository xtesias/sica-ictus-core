{
  "name": "@api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "uv run uvicorn src.main:app --host 0.0.0.0 --port 8000 --reload",
    "build": "uv sync",
    "start": "uv run uvicorn src.main:app --host 0.0.0.0 --port 8000",
    "lint": "uv run ruff check src tests",
    "format": "uv run ruff format src tests",
    "type-check": "uv run mypy src",
    "test": "uv run pytest",
    "clean": "rm -rf .venv .pytest_cache .ruff_cache .mypy_cache __pycache__"
  }
}