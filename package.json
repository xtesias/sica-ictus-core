{
  "name": "sica-ictus-core",
  "version": "0.1.0",
  "private": true,
  "description": "DeFi bug hunting platform — knowledge management, ML recommender, hunt workspace",
  "license": "UNLICENSED",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "clean": "rm -rf .turbo node_modules .next out build dist"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.16",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18",
     "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
